# .env

# --- データベース設定 ---
# docker-compose.ymlで定義するMySQLサービスの情報を指定
DATABASE_URL=mysql+pymysql://root:password@mysql/app_db

# --- Celery設定 ---
# docker-compose.ymlで定義するRedisサービスの情報を指定
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- JWT認証トークン設定 ---
# AuthServiceで使用する秘密鍵。本番環境では必ず複雑な文字列に変更してください。
SECRET_KEY=your-super-secret-key-that-is-long-and-random
# トークンのアルゴリズム
ALGORITHM=HS256
# トークンの有効期限（分）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Ollama設定 ---
# docker-compose.ymlで定義するOllamaサービスの情報を指定
OLLAMA_BASE_URL=http://ollama:11434
# 使用するLLMモデル名
OLLAMA_MODEL=llama3:8b-instruct-q5_K_M

